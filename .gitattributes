# Unity YAML 파일 — 병합 시 Unity Smart Merge 사용, 텍스트로 취급
*.cs               text diff=csharp
*.shader           text
*.cginc            text
*.json             text
*.md               text
*.txt              text

# Unity 직렬화 에셋 (YAML) — 텍스트, CRLF 강제 안 함
*.meta             -text merge=unityyamlmerge
*.unity            -text merge=unityyamlmerge
*.asset            -text merge=unityyamlmerge
*.prefab           -text merge=unityyamlmerge
*.mat              -text merge=unityyamlmerge
*.anim             -text merge=unityyamlmerge
*.controller       -text merge=unityyamlmerge
*.scenetemplate    -text
*.inputactions     -text

# 바이너리 에셋 (diff/merge 안 함)
*.png              binary
*.jpg              binary
*.jpeg             binary
*.gif              binary
*.psd              binary
*.aseprite         binary
*.ase              binary
*.wav              binary
*.mp3              binary
*.ogg              binary
*.ttf              binary
*.otf              binary
*.fbx              binary
*.unitypackage     binary
